# ============================================================================
# Sealed Deck — environment template. Copy to .env and fill in.
# .env is gitignored. Use a FRESH throwaway wallet funded from the Fuji faucet.
# ============================================================================

# ---- Chain / contracts ----
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
CHAIN_ID=43113
# Throwaway deployer/private key (NO real funds). Used by Foundry deploy + server signer.
PRIVATE_KEY=0xYOUR_THROWAWAY_PRIVATE_KEY
# Routescan/Snowtrace verification key (a placeholder like "verifyContract" works on testnet).
SNOWTRACE_API_KEY=verifyContract

# Deployed PokerTable address (filled after `forge script Deploy`).
POKER_TABLE_ADDRESS=

# Table parameters used by the deploy script (wei).
BUY_IN_WEI=50000000000000000        # 0.05 AVAX
SMALL_BLIND_WEI=500000000000000     # 0.0005 AVAX
BIG_BLIND_WEI=1000000000000000      # 0.001 AVAX
TIMEOUT_BLOCKS=30

# ---- Server ----
# Bind to 0.0.0.0 so the game is reachable over your VPN/LAN during the demo.
SERVER_HOST=0.0.0.0
SERVER_PORT=8787
# Public base URL the FRONTEND uses to reach the server (set to the host's VPN IP for remote play).
# e.g. http://100.x.y.z:8787  (Tailscale) or http://<mac-vpn-ip>:8787
PUBLIC_SERVER_URL=http://localhost:8787

# ---- Buy-in / betting path ----
# In-hand bets are ALWAYS on-chain accounting against the staked buy-in (correct for a
# trustless pot). The choice is how the BUY-IN is funded:
#   'avax'      -> AVAX-denominated table (PokerTable). Default; nothing extra needed.
#   'x402-usdc' -> USDC-denominated table (PokerTableUSDC) funded by x402 / EIP-3009.
BETTING_PATH=avax

# ---- x402 USDC buy-in (Avalanche Fuji) ----
# Avalanche native Circle USDC on Fuji (EIP-3009). Faucet: https://faucet.circle.com
X402_ASSET_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65
# Deployed USDC table (from `forge script DeployUSDC`).
POKER_TABLE_USDC_ADDRESS=
# Settlement is done by an x402 facilitator. Pick ONE:
#   (A) external Avalanche facilitator URL (Thirdweb x402 / PayAI / Ultravioleta / x402-rs)
X402_FACILITATOR_URL=
#   (B) self-facilitator: this server submits joinWithAuthorization with a relayer key
#       (separate from the card-relay role, which still holds no key).
X402_RELAYER_KEY=

# ---- Frontend (Vite needs the VITE_ prefix; see frontend/.env) ----
# For the VPN demo set VITE_PUBLIC_SERVER_URL to the Mac's VPN IP, e.g. http://100.x.y.z:8787
VITE_PUBLIC_SERVER_URL=http://localhost:8787
VITE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
VITE_POKER_TABLE_ADDRESS=
VITE_CHAIN_ID=43113
